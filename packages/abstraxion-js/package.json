{
  "name": "@burnt-labs/abstraxion-js",
  "version": "1.0.0-alpha.0",
  "main": "./dist/index.js",
  "scripts": {
    "test": "vitest",
    "test:integration": "vitest run tests/integration --config vitest.config.integration.ts",
    "test:integration:watch": "vitest tests/integration --config vitest.config.integration.ts",
    "test:contract": "vitest run --config vitest.config.contract.ts",
    "build": "tsup",
    "lint": "eslint src/",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rimraf ./dist"
  },
  "license": "MIT",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/burnt-labs/xion.js",
    "directory": "packages/abstraxion-js"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@burnt-labs/test-utils": "workspace:*",
    "@cosmjs/amino": "^0.36.0",
    "@cosmjs/crypto": "^0.36.0",
    "@cosmjs/encoding": "^0.36.0",
    "@cosmjs/tendermint-rpc": "^0.36.0",
    "@types/node": "^20",
    "dotenv": "^16.4.5",
    "ethers": "^6",
    "playwright": "1.48.0",
    "playwright-core": "1.48.0",
    "rimraf": "^5.0.5",
    "tsup": "^6.0.1",
    "typescript": "^5.2.2",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@burnt-labs/abstraxion-core": "workspace:*",
    "@burnt-labs/account-management": "workspace:*",
    "@burnt-labs/constants": "workspace:*",
    "@burnt-labs/signers": "workspace:*",
    "@cosmjs/cosmwasm-stargate": "^0.36.0",
    "@cosmjs/proto-signing": "^0.36.0",
    "@cosmjs/stargate": "^0.36.0"
  }
}
