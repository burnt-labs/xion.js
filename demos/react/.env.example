# ===== CHAIN CONFIGURATION =====
VITE_CHAIN_ID=xion-testnet-2
VITE_RPC_URL=https://rpc.xion-testnet-2.burnt.com:443
VITE_REST_URL=https://api.xion-testnet-2.burnt.com
VITE_GAS_PRICE=0.001uxion

# ===== AUTH DASHBOARD URLs =====
# Used by popup mode
VITE_AUTH_APP_URL=https://auth.testnet.burnt.com
# Used by embedded (iframe) mode
VITE_IFRAME_URL=https://auth.testnet.burnt.com

# ===== TREASURY =====
# Treasury contract address — enables dynamic grant configs
VITE_TREASURY_ADDRESS=xion1z70cvc08qv5764zeg3dykcyymj5z6nu4sqr7x8vl4zjef2gyp69s9mmdka

# ===== CONTRACT EXECUTION DEMO =====
# Used by the direct-signing card's "Execute Contract" tab.
VITE_DEMO_CONTRACT_ADDRESS=xion1shle62n59n7mfs9pmtgy26cs5xm0jtjrcjzpp0a2c7z88gd9np5qx6xpm5

# ===== SIGNER MODE (Turnkey) =====
# Required to render the /signer-mode demo. The page shows a setup-required
# screen if VITE_TURNKEY_ORG_ID is missing.
VITE_TURNKEY_ORG_ID=
VITE_TURNKEY_API_BASE_URL=https://api.turnkey.com

# ===== ACCOUNT ABSTRACTION API =====
# Required for signer mode (account creation calls)
VITE_AA_API_URL=https://aa-api.xion-testnet-2.burnt.com

# ===== SMART ACCOUNT CONTRACT (signer mode) =====
# Must match your AA API's .dev.vars exactly.
VITE_CODE_ID=1
VITE_CHECKSUM=FC06F022C95172F54AD05BC07214F50572CDF684459EADD4F58A765524567DB8
VITE_FEE_GRANTER_ADDRESS=xion1xrqz2wpt4rw8rtdvrc4n4yn5h54jm0nn4evn2x
VITE_ADDRESS_PREFIX=xion

# ===== INDEXER (signer mode, optional) =====
# Falls back to RPC if not set. Pick one of the two indexer types:
# Subquery (no token needed):
# VITE_INDEXER_TYPE=subquery
# VITE_INDEXER_URL=https://api.subquery.network/sq/burnt-labs/xion-testnet-2-indexer
# Numia (requires token):
# VITE_INDEXER_TYPE=numia
# VITE_INDEXER_URL=https://xion-testnet-2.numia.xyz/v3
# VITE_INDEXER_TOKEN=

# ===== TREASURY INDEXER (optional) =====
VITE_TREASURY_INDEXER_URL=https://daodaoindexer.burnt.com
